# ShubaTapoChan .env テンプレート
# 実運用では .env にコピーして値を埋める。.env は .gitignore 済。

# --- GPU PC (処理を行うサーバー) ---
GPU_SERVER_HOST=133.15.57.36
GPU_SERVER_USER=nishimura
GPU_SERVER_SSH_KEY=~/.ssh/id_Rasiel

# --- TAPO C220 ---
# RTSP / マイク入力用 (Tapo アプリ → 詳細設定 → カメラアカウント)
TAPO_CAMERA_HOST=192.168.x.x
TAPO_CAMERA_USER=your_rtsp_user
TAPO_CAMERA_PASSWORD=your_rtsp_password

# 双方向音声 (go2rtc tapo://) 用: TP-Link クラウドアカウントのパスワード
# ユーザ名は不要。空にすると C220 スピーカ出力 (SHUBATAPO_AUDIO_OUT=tapo) が無効。
TAPO_CLOUD_PASSWORD=

# --- LLM ---
# API 課金: どちらか片方（ANTHROPIC_API_KEY があれば優先）
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=

# Max プラン枠で Claude Agent SDK を使う場合 (claude setup-token で取得)
CLAUDE_CODE_OAUTH_TOKEN=

# --- 任意の上書き ---
# TTS_BASE_URL=http://localhost:8766
# SHUBATAPO_LLM_BACKEND=api          # api | code
# SHUBATAPO_LLM_MODEL=claude-haiku-4-5
# SHUBATAPO_PERSONA=subaru            # personas/<name>.yaml
# SHUBATAPO_AUDIO_OUT=mac             # mac | tapo | both
# SHUBATAPO_GO2RTC_URL=http://127.0.0.1:1984
# SHUBATAPO_AUDIO_GAIN=50.0           # RTSP 入力の digital gain
